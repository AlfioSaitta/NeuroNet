# ==============================================================================
# ECOSISTEMA AI LOCALE — ESEMPIO DI CONFIGURAZIONE
# ==============================================================================
# Copiare questo file in .env e modificare i valori secondo le proprie esigenze.
# Non committare MAI il file .env nel repository.
# ==============================================================================

# ==============================================================================
# PERCORSI CENTRALIZZATI
# ==============================================================================
# DATA_DIR: dati persistenti (stato RAG, cache, backup Mem0)
#   Docker: /app/mem0_data_v3 (valore di default, volume montato)
#   Host:   ./data/jarvis_mem0
DATA_DIR=

# MODELS_DIR: directory dei modelli GGUF, reranker, embedding
#   Docker: /app/models (valore di default)
#   Host:   ./models
MODELS_DIR=

# DOCUMENTS_DIR: directory dei documenti monitorati per RAG
#   Docker: /app/documents (valore di default)
#   Host:   ./data/documents
DOCUMENTS_DIR=

# HOST_FS_PREFIX: prefisso per mount del filesystem host in Docker.
#   Docker: /host_fs (valore di default — traduce /host_fs/home/... in path reali)
#   Host:   vuoto (i path di EXTERNAL_PROJECTS sono già assoluti)
HOST_FS_PREFIX=

# ==============================================================================
# INTEGRAZIONI ESTERNE
# ==============================================================================

# Credenziali Bot Telegram rilasciate da @BotFather
TELEGRAM_TOKEN=

# ID Telegram degli utenti autorizzati ad interagire col bot (separati da virgola)
ALLOWED_USERS=

# ==============================================================================
# IMPOSTAZIONI DI SISTEMA (Mem0 Proxy)
# ==============================================================================

# Modello di embedding (qwen3-embedding-0.6b, nomic-embed-text-v1.5, ecc.)
EMBEDDING_MODEL=qwen3-embedding-0.6b

# Modello FlashRank per Re-Ranking RAG
# Opzioni: ms-marco-TinyBERT-L-2-v2, ms-marco-MiniLM-L-12-v2
FLASHRANK_MODEL=ms-marco-TinyBERT-L-2-v2

# Suffisso versione Vector DB (cambiare forza la creazione di nuove collezioni)
VECTOR_DB_VERSION=v3

# Limiti di traffico API
API_RATE_LIMIT_DEFAULT=60/minute
API_RATE_LIMIT_HEAVY=5/minute

# Debounce watchdog filesystem (secondi)
WATCHDOG_BATCH_DELAY=1.0

# Soglia cache semantica (0.0 - 1.0)
SEMANTIC_CACHE_THRESHOLD=0.96

# Ritardo avvio Mem0 (secondi)
MEM0_STARTUP_DELAY=4.0

# ==============================================================================
# MODELLO LLM — Worker GPU (llama-cpp-python con GGUF)
# ==============================================================================

# Percorso del file GGUF del modello chat (relativo a /app nel container)
LLAMA_MODEL_PATH=./models/Qwen3.5-4B-UD-Q4_K_XL.gguf

# Layer da caricare in GPU (0 = CPU-only, 15 = ~2.9GB su RTX 3050 Ti 4GB)
N_GPU_LAYERS=15

# Etichetta modello passata al Master durante offloading
OLLAMA_MODEL=gemma-4-E2B-worker

# ==============================================================================
# ARCHITETTURA MASTER/WORKER
# ==============================================================================

# Telegram disabilitato sul Worker (gestito dal Master sulla VPS)
TELEGRAM_ENABLED=false

# Host Qdrant (nome container in modalità Offline, IP Tailscale in Online)
# Docker: qdrant
# Host:   localhost (Qdrant su Docker con porta 6333 esposta)
# Online: 100.64.0.1 (Tailscale del Master VPS)
QDRANT_HOST=localhost

# Host SearXNG
# Docker: http://searxng:8080
# Host:   http://localhost:8081
SEARXNG_HOST=http://localhost:8081

# Host Crawl4AI
# Docker: http://crawl4ai:11235
# Host:   http://localhost:11235
CRAWL4AI_HOST=http://localhost:11235

# URL del nodo GPU esterno (lasciare vuoto sul Worker)
EXTERNAL_GPU_URL=

# ==============================================================================
# HYPERPARAMETERS LLM
# ==============================================================================

LLM_TEMPERATURE=0.7
LLM_REPEAT_PENALTY=1.1
LLM_TOP_P=0.9
LLM_NUM_CTX=12288
LLM_NUM_PREDICT=2048
LLM_BATCH_SIZE=512
LLM_UBATCH_SIZE=128
LLM_FLASH_ATTN=true
LLM_THINKING_MODE=false

# ==============================================================================
# RAG (Retrieval-Augmented Generation)
# ==============================================================================

RAG_SCORE_THRESHOLD_CODE=0.40
RAG_SCORE_THRESHOLD_DOCS=0.32
RAG_TOP_K_CODE=5
RAG_TOP_K_DOCS=3

# ==============================================================================
# PROGETTI ESTERNI PER RAG
# ==============================================================================

# Formato: /percorso/assoluto/:NomeProgetto (separati da virgola)
EXTERNAL_PROJECTS=

# ==============================================================================
# TELEGRAM USERBOT
# ==============================================================================

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
ALLOWED_PRIVATE_CHATS=

# ==============================================================================
# PROVIDER ESTERNI (Gemini, Claude, ecc.)
# ==============================================================================

# --- Google Gemini ---
# API key per Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Modello Gemini da utilizzare
# Opzioni: gemini-2.5-pro-exp-03-25, gemini-2.0-flash, gemini-2.0-flash-lite
GEMINI_MODEL=gemini-2.5-pro-exp-03-25

# Strategia di routing per provider esterni
# Opzioni:
#   fallback_only  — Usa provider esterno solo se locale fallisce (default)
#   selective      — Routing basato sul tipo di richiesta (web → cloud, codice → locale)
#   parallel       — Chiama tutti in parallelo, sceglie il migliore
#   multimodal     — Solo per richieste con immagini/media
EXTERNAL_PROVIDER_STRATEGY=fallback_only
