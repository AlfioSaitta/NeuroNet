# ==============================================================================
# ECOSISTEMA AI LOCALE — ESEMPIO DI CONFIGURAZIONE
# ==============================================================================
# Copiare questo file in .env e modificare i valori secondo le proprie esigenze.
# I valori qui riportati sono i DEFAULT di fabbrica, adatti a un primo avvio.
# Non committare MAI il file .env nel repository.
# ==============================================================================


# ==============================================================================
# LOGGING
# ==============================================================================
# Livello di logging globale
# Opzioni: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
#LOG_LEVEL=INFO


# ==============================================================================
# PERCORSI CENTRALIZZATI
# ==============================================================================
# DATA_DIR: dati persistenti (stato RAG, cache HF, backup Mem0, task, cron)
#   Docker: /app/mem0_data_v3 (default del container)
#   Host:   path assoluto sul filesystem
# Contiene: rag_state_*.json, memory_backup.json, infrastructure.json,
#           cache HuggingFace/FastEmbed/tiktoken, cron_jobs.json, tasks.json
DATA_DIR=

# MODELS_DIR: directory dei modelli GGUF (chat, embedding, reranker)
#   Docker: /app/models (default del container)
#   Host:   path assoluto
MODELS_DIR=

# DOCUMENTS_DIR: directory dei documenti monitorati per RAG (symlink esterni)
#   Docker: /app/documents
#   Host:   path assoluto
DOCUMENTS_DIR=

# HOST_FS_PREFIX: prefisso per tradurre path host in path container (solo Docker)
#   Docker: /host_fs (default — /host_fs/home/... → /home/...)
#   Host:   lascia vuoto (i path di EXTERNAL_PROJECTS sono già assoluti)
HOST_FS_PREFIX=

# WORKSPACE_DIR: directory principale per auto-scoperta progetti RAG.
# Ogni subdirectory non nascosta viene trattata come un progetto separato
# con una propria collezione Qdrant.
#   Docker: /host_fs/home/alfio/Projects
#   Host:   /home/alfio/Projects
# Opzioni: path assoluto, oppure vuoto per disabilitare auto-scoperta
WORKSPACE_DIR=


# ==============================================================================
# MODELLO LLM — Worker GPU (llama-cpp-python con GGUF)
# Hardware: LENOVO IdeaPad Gaming 3, RTX 3050 Ti Laptop GPU (4GB VRAM)
# Jarvis NON usa Ollama — usa esclusivamente llama-cpp-python con file GGUF.
# Il modello viene caricato all'avvio e mantenuto caldo in VRAM.
# ==============================================================================

# LLAMA_MODEL_PATH: percorso del file GGUF del modello chat
#   Valore: path assoluto o relativo a /app (Docker)
#   Opzioni: ./models/gemma-4-E2B-it-qat-UD-Q4_K_XL.gguf, ./models/Qwen3.5-4B-UD-Q4_K_XL.gguf
LLAMA_MODEL_PATH=./models/Qwen3.5-4B-UD-Q4_K_XL.gguf

# LLAMA_EMBED_MODEL_PATH: percorso del file GGUF per embedding
#   Default: ./models/Qwen3-Embedding-0.6B-Q8_0.gguf (768d MRL, Q8_0, ~400MiB VRAM)
#   Opzioni: nomic-embed-text-v1.5.gguf (CPU, più lento)
LLAMA_EMBED_MODEL_PATH=./models/Qwen3-Embedding-0.6B-Q8_0.gguf

# N_GPU_LAYERS: layer da caricare in GPU (0 = CPU-only)
#   RTX 3050 Ti 4GB VRAM: 15 è il massimo stabile con Gemma 4 E2B QAT
#   Oltre 15 → segfault su Gemma 4 E2B QAT (35 blocchi, Q4_0 con CUDA_Host)
#   Oltre 22 → CUDA OOM garantito durante llama_decode
#   Opzioni: 0 (CPU), 1-15 (misto GPU/CPU), 99 (tutto GPU)
N_GPU_LAYERS=15

# LLM_NUM_CTX: finestra di contesto in token
#   Worker GPU (4GB VRAM): 12288 è il sweet spot (libera ~256MiB dalla KV cache)
#   16384+ causa picchi VRAM durante prompt processing → CUDA OOM
#   Master VPS (CPU, 24GB RAM): 32768 consigliato
#   Opzioni: 4096, 8192, 12288, 16384, 32768, 65536
# Nota: valori alti aumentano la qualità RAG ma consumano più VRAM/RAM
LLM_NUM_CTX=12288

# LLM_BATCH_SIZE: batch per prompt processing (token paralleli)
#   512 = sweet spot TTFT (7.8s vs 14s con 2048)
#   Valori bassi (64-128) riducono picchi VRAM ma peggiorano TTFT
#   Opzioni: 64, 128, 256, 512, 1024
LLM_BATCH_SIZE=512

# LLM_UBATCH_SIZE: micro-batch per CUDA graph interno
#   Limita i buffer intermedi GPU durante prompt processing
#   n_ubatch=128 con n_batch=512: buon bilanciamento VRAM/TTFT
#   Opzioni: 64, 128, 256 (deve essere ≤ LLM_BATCH_SIZE)
LLM_UBATCH_SIZE=128

# LLM_FLASH_ATTN: Flash Attention (riduce VRAM KV cache, accelera prompt processing)
#   Opzioni: true, false
#   true = richiede GPU con supporto CUDA ≥ 11.6 (RTX 3050 Ti ✅ via CUDA 13.0)
#   false = compatibile ma usa più VRAM per la cache
LLM_FLASH_ATTN=true

# LLM_THINKING_MODE: thinking mode specifico del modello (tag <|think|>)
#   Gemma 4:    supportato ✅ (default: true)
#   Qwen3.5:    NON supportato ❌ (default: false, ignorato)
#   DeepSeek:   supportato ✅
#   Opzioni: true, false, oppure lascia vuoto per auto-rilevamento dal GGUF
LLM_THINKING_MODE=false

# LLM_CHAT_FORMAT: forza un formato chat specifico (sovrascrive auto-rilevamento)
#   Opzioni: auto (lascia vuoto), chatml, gemma, llama, qwen, deepseek, mistral, phi
#   Default: auto-rilevato dal nome del file GGUF tramite model_profiles.py
#LLM_CHAT_FORMAT=

# LLM_TEMPERATURE: temperatura del modello (creatività)
#   Gemma 4:  1.0 valore consigliato da Unsloth
#   Qwen3.5:  0.7 per coding, 1.0+ causa output caotici
#   Opzioni: 0.0 (deterministico), 0.7 (bilanciato), 1.0 (creativo), 1.5 (caotico)
LLM_TEMPERATURE=0.7

# LLM_REPEAT_PENALTY: penalità per evitare ripetizioni di token
#   Opzioni: 1.0 (nessuna), 1.1 (leggera), 1.2 (media), 1.5 (forte)
LLM_REPEAT_PENALTY=1.1

# LLM_TOP_P: nucleus sampling (cumulative probability cutoff)
#   Opzioni: 0.8 (più focalizzato), 0.9 (bilanciato), 0.95 (più varietà), 1.0 (disabilitato)
LLM_TOP_P=0.9

# LLM_TOP_K: top-k sampling (numero di token candidati)
#   Opzioni: 20, 40, 50 (default modello), 100
#   Default: 40
#LLM_TOP_K=40

# LLM_PRESENCE_PENALTY: penalità per argomenti/topic già menzionati
#   Opzioni: 0.0 (nessuna), 0.5 (leggera), 1.0 (forte)
#   Default: 0.0
#LLM_PRESENCE_PENALTY=0.0

# LLM_FREQUENCY_PENALTY: penalità per token già usati di frequente
#   Opzioni: 0.0 (nessuna), 0.5 (leggera), 1.0 (forte)
#   Default: 0.0
#LLM_FREQUENCY_PENALTY=0.0

# LLM_NUM_PREDICT: limite massimo token output per risposta
#   Opzioni: 1024 (conciso), 2048 (bilanciato), 4096 (lunghi), 8192 (analisi estese)
#   Valori alti aumentano la latenza percepita
LLM_NUM_PREDICT=2048
LLM_MAX_TOKENS=2048

# OLLAMA_MODEL: etichetta testuale per identificare il modello nei log e nel payload
#   NON serve per l'inferenza (Jarvis non usa Ollama)
#   Usato come metadata nei log del Master durante offloading GPU
#   Opzioni: qualsiasi stringa descrittiva
OLLAMA_MODEL=qwen2.5-coder:3b-instruct-q5_K_M


# ==============================================================================
# IMPOSTAZIONI DI SISTEMA (Embedding, Reranker, Mem0)
# ==============================================================================

# EMBEDDING_MODEL: modello per embedding dei documenti
#   Opzioni: qwen3-embedding-0.6b, nomic-embed-text-v1.5
EMBEDDING_MODEL=qwen3-embedding-0.6b

# EMBEDDING_DIMS: dimensioni del vettore di embedding (output MRL troncato)
#   Qwen3 nativo: 1024; troncato MRL: 768
#   Deve corrispondere alla dimensione delle collezioni Qdrant esistenti
#   Se cambi, devi anche cambiare VECTOR_DB_VERSION per forzare nuove collezioni
#   Opzioni: 768 (default), 1024 (MRL intero)
EMBEDDING_DIMS=768

# FLASHRANK_MODEL: modello di re-ranking per risultati RAG (fallback ONNX)
#   Opzioni:
#     ms-marco-TinyBERT-L-2-v2 (veloce, leggero — default)
#     ms-marco-MiniLM-L-6-v2  (migliore qualità, più lento)
#     ms-marco-MiniLM-L-12-v2 (massima qualità, heavy)
FLASHRANK_MODEL=ms-marco-TinyBERT-L-2-v2

# RERANKER_DEVICE: device per il reranker principale (Qwen3-Reranker)
#   Opzioni: cpu (non ruba VRAM alla chat), cuda (più veloce)
#   Default: cpu
RERANKER_DEVICE=cpu

# VECTOR_DB_VERSION: suffisso versioni collezioni Qdrant.
#   Cambiare forza la creazione di nuove collezioni pulite, ignorando vecchi dati.
#   Utile se cambi EMBEDDING_MODEL o EMBEDDING_DIMS (dimensioni vettoriali diverse).
#   Opzioni: v1, v2, v3, ... (qualsiasi stringa)
VECTOR_DB_VERSION=v1

# RAG_CHUNK_SIZE: dimensione in caratteri di ogni chunk per RAG
#   Opzioni: 256 (grana fine), 512 (default, bilanciato), 1024 (contesto più ricco)
#RAG_CHUNK_SIZE=512

# RAG_CHUNK_OVERLAP: sovrapposizione tra chunk consecutivi (caratteri)
#   Opzioni: 0 (nessuna), 32-64 (leggera), 128 (massima copertura)
#RAG_CHUNK_OVERLAP=0

# RAG_EMBEDDING_BATCH_SIZE: numero massimo di embedding concorrenti
#   Opzioni: 4 (poco VRAM), 8 (bilanciato), 16 (veloce ma più VRAM)
#RAG_EMBEDDING_BATCH_SIZE=8

# SEMANTIC_CACHE_THRESHOLD: soglia similarità cosine per cache semantica (0.0 - 1.0)
#   Opzioni: 0.90 (tollerante, più hit), 0.96 (bilanciato), 0.99 (esatto, pochi hit)
SEMANTIC_CACHE_THRESHOLD=0.96

# MEM0_STARTUP_DELAY: secondi di attesa all'avvio prima di inizializzare Mem0
#   Utile per dare tempo a Qdrant di essere pronto (specie in Docker)
#   Opzioni: 0.0 (nessun delay), 2.0 (leggero), 4.0 (default, sicuro)
MEM0_STARTUP_DELAY=4.0


# ==============================================================================
# RAG (Retrieval-Augmented Generation) — Soglie e recupero
# ==============================================================================

# Soglie minime di similarità per recuperare chunk (0.0 - 1.0)
#   RAG_SCORE_THRESHOLD_CODE: per chunk di codice (default: 0.40)
#   RAG_SCORE_THRESHOLD_DOCS: per chunk di documentazione (default: 0.32)
#   Opzioni: 0.20 (tutto), 0.40 (bilanciato), 0.60 (solo pertinenti), 0.80 (molto stretto)
RAG_SCORE_THRESHOLD_CODE=0.40
RAG_SCORE_THRESHOLD_DOCS=0.32

# Numero di chunk da passare al LLM come contesto
#   Più chunk = contesto migliore ma più token usati (vedi LLM_NUM_CTX)
#   RAG_TOP_K_CODE: 1-10 per codice (default: 5)
#   RAG_TOP_K_DOCS: 1-5 per documenti testuali (default: 3)
RAG_TOP_K_CODE=5
RAG_TOP_K_DOCS=3


# ==============================================================================
# PROGETTI ESTERNI PER RAG (mount dinamici)
# ==============================================================================
# Lista di cartelle esterne da includere nel RAG, oltre a WORKSPACE_DIR.
# Formato: /path/assoluto/:NomeProgetto (separati da virgola)
#   /path/assoluto/ deve esistere sul filesystem
#   NomeProgetto diventa il nome della collezione Qdrant
# Esempio: "/home/user/ProgettoX/:ProgettoX, /home/user/Altro/:Altro"
EXTERNAL_PROJECTS=

# GIT_WEBHOOK_SECRET: segreto per validare webhook Git (pull automatico + re-ingestione RAG)
#   Lascia vuoto per disabilitare la validazione
#GIT_WEBHOOK_SECRET=


# ==============================================================================
# WATCHDOG FILESYSTEM — PollingObserver per ri-embedding automatico
# ==============================================================================
# Monitora i progetti RAG e ri-vettorializza automaticamente i file modificati.

# WATCHDOG_ENABLED: abilita/disabilita il watchdog
#   Opzioni: true, false
#   default: auto-detect basato su presenza libreria watchdog
WATCHDOG_ENABLED=true

# WATCHDOG_TIMEOUT: intervallo di polling in secondi
#   1 = massima reattività (ma 88% CPU con 335K file — sconsigliato senza per_project)
#   5 = buon bilanciamento reattività/CPU (default)
#   10 = CPU minimo, meno reattivo
#   Opzioni: 1, 2, 5, 10, 30
WATCHDOG_TIMEOUT=5

# WATCHDOG_WATCH_MODE: quali directory monitorare
#   "per_project" = solo le directory dei progetti indicizzati (default, ~30x meno file)
#   "full" = ricorsivamente tutta WORKSPACE_DIR (include node_modules, .git, venv)
#   Opzioni: per_project, full
WATCHDOG_WATCH_MODE=per_project

# WATCHDOG_BATCH_DELAY: debounce in secondi per accorpare modifiche rapide ai file
#   1.0 = veloce (utile per IDE che salvano spesso)
#   2.5 = bilanciato
#   5.0 = sicuro (aspetta che tutte le modifiche siano complete)
#   Opzioni: 0.5, 1.0, 2.5, 5.0
WATCHDOG_BATCH_DELAY=1.0


# ==============================================================================
# LIMITI DI TRAFFICO API (rate limiting)
# ==============================================================================
# Formato: "numero/intervallo" (es. 60/minute, 5/second, 100/hour)
# Prevengono sovraccarichi e loop accidentali.

API_RATE_LIMIT_DEFAULT=60/minute
API_RATE_LIMIT_HEAVY=5/minute
API_RATE_LIMIT_EMBED=600/minute


# ==============================================================================
# ARCHITETTURA MASTER/WORKER
# ==============================================================================

# EXTERNAL_GPU_URL: URL del nodo GPU esterno per offloading inferenza
#   Worker locale: lascia vuoto (è lui il target, non delega a nessuno)
#   Master VPS: http://100.64.0.2:8000 (IP Tailscale del Worker)
#   Se impostato, il Master pinga il Worker con timeout 1.5s e offloada via HTTP POST
#   Se il Worker è offline, fallback a CPU locale
EXTERNAL_GPU_URL=

# BOT_NAME: nome visualizzato del bot (usato nei log e risposte)
#   Opzioni: qualsiasi stringa
#   Default: Jarvis
#BOT_NAME=Jarvis


# ==============================================================================
# SERVIZI ESTERNI (Qdrant, SearXNG, Crawl4AI)
# ==============================================================================

# QDRANT_HOST: host del database vettoriale Qdrant
#   Docker: qdrant (nome container)
#   Host:   localhost (container con porta 6333 esposta)
#   Online (Tailscale VPS): 100.64.0.1
#   Locale (standalone): local
QDRANT_HOST=localhost

# SEARXNG_HOST: URL completo del metasearch SearXNG
#   Docker: http://searxng:8080
#   Host:   http://localhost:8081
#   Opzioni: URL valido, oppure vuoto per disabilitare ricerca web
SEARXNG_HOST=http://localhost:8081

# CRAWL4AI_HOST: URL dello scraper headless Crawl4AI
#   Docker: http://crawl4ai:11235
#   Host:   http://localhost:11235
#   Opzioni: URL valido, oppure vuoto per disabilitare crawling
CRAWL4AI_HOST=http://localhost:11235


# ==============================================================================
# INTEGRAZIONE TELEGRAM — BOT UFFICIALE
# ==============================================================================

# TELEGRAM_ENABLED: abilita/disabilita il bot Telegram
#   Worker locale: false (centralizzato sul Master VPS)
#   Master VPS: true
#   Opzioni: true, false, auto (rilevamento automatico da presenza libreria)
TELEGRAM_ENABLED=false

# TELEGRAM_TOKEN: token del bot rilasciato da @BotFather
#   Necessario solo se TELEGRAM_ENABLED=true
#   Opzioni: stringa "123456:ABC-DEF..." oppure vuoto
TELEGRAM_TOKEN=

# ALLOWED_USERS: ID Telegram degli utenti autorizzati (separati da virgola)
#   Si trova in Impostazioni → Avanzate → ID utente Telegram
#   Opzioni: lista di numeri interi, oppure vuoto (solo admin via allowed_users.json)
ALLOWED_USERS=


# ==============================================================================
# TELEGRAM USERBOT (Telethon) — Risposte automatiche in Chat Private
# ==============================================================================
# Richiede: credenziali da https://my.telegram.org/apps

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
ALLOWED_PRIVATE_CHATS=


# ==============================================================================
# MCP — Model Context Protocol (tool esterni)
# ==============================================================================
# MCP permette a Jarvis di usare tool esterni tramite server MCP.

MCP_ENABLED=true
MCP_AUTO_INIT=true
MCP_SKILL_EMBEDDED=true

# MCP_CONFIG_PATHS: percorsi aggiuntivi per file di configurazione MCP (separati da virgola)
#   Opzioni: lista di path JSON, oppure vuoto (solo configurazione embedded)
#MCP_CONFIG_PATHS=


# ==============================================================================
# PROVIDER ESTERNI (Gemini, Claude, ecc.)
# ==============================================================================

# --- Google Gemini ---
# GEMINI_API_KEY: API key per Google Gemini
#   Ottenere da: https://aistudio.google.com/apikey
#   Opzioni: stringa API key, oppure vuoto per disabilitare
GEMINI_API_KEY=

# GEMINI_MODEL: modello Gemini da utilizzare
#   Opzioni:
#     gemini-2.5-pro-exp-03-25 (massima qualità, più lento)
#     gemini-2.0-flash         (veloce, buono per task semplici)
#     gemini-2.0-flash-lite    (leggerissimo, massima velocità)
GEMINI_MODEL=gemini-2.5-pro-exp-03-25

# EXTERNAL_PROVIDER_STRATEGY: strategia di routing per provider esterni
#   Opzioni:
#     fallback_only — Usa provider esterno solo se locale fallisce (default)
#     selective     — Routing basato sul tipo: web → cloud, codice → locale
#     parallel      — Chiama tutti i provider in parallelo, sceglie il migliore
#     multimodal    — Solo per richieste con immagini/media
EXTERNAL_PROVIDER_STRATEGY=fallback_only
