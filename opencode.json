{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  },
  "agent": {
    "jarvis-build": {
      "description": "Jarvis Build Agent — sviluppo con tutti i tool abilitati",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "skill": "allow",
        "todowrite": "allow"
      }
    },
    "jarvis-plan": {
      "description": "Jarvis Plan Agent — analisi e pianificazione senza modifiche",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "skill": "allow"
      }
    }
  }
}
